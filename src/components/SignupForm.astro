---
// SignupForm.astro – Share Your Story signup form
---

<section class="signup" id="signup">
  <div class="container">
    <h2 class="section__title">Are You Ready?</h2>
    <p class="section__subtitle">
      Unscripted, stress-free, one-on-one creative capture of short recovery stories to share experience, strength and hope.
    </p>

    <div class="signup__features">
      <div class="signup__feature">
        <span class="signup__feature-icon" aria-hidden="true">&#128663;</span>
        <span>Road-trip style interviews</span>
      </div>
      <div class="signup__feature">
        <span class="signup__feature-icon" aria-hidden="true">&#128172;</span>
        <span>Engaging dialogue</span>
      </div>
      <div class="signup__feature">
        <span class="signup__feature-icon" aria-hidden="true">&#9728;&#65039;</span>
        <span>Fresh air and sunshine</span>
      </div>
      <div class="signup__feature">
        <span class="signup__feature-icon" aria-hidden="true">&#129309;</span>
        <span>Community driven</span>
      </div>
      <div class="signup__feature">
        <span class="signup__feature-icon" aria-hidden="true">&#10084;&#65039;</span>
        <span>Recovery focused</span>
      </div>
    </div>

    <form class="signup__form" id="signupForm" name="signup" method="POST" data-netlify="true" netlify-honeypot="bot-field">
      <input type="hidden" name="form-name" value="signup">
      <p hidden><input name="bot-field"></p>

      <div class="signup__field">
        <label for="name">Your Name <span class="signup__required">*</span></label>
        <input type="text" id="name" name="name" required placeholder="Enter your name">
      </div>

      <div class="signup__field">
        <label for="email">Your Email <span class="signup__required">*</span></label>
        <input type="email" id="email" name="email" required placeholder="Enter your email">
      </div>

      <div class="signup__field">
        <label for="sobrietyDate">Sobriety Date</label>
        <input type="text" id="sobrietyDate" name="sobrietyDate" placeholder="MM/DD/YYYY (optional)">
      </div>

      <div class="signup__field signup__field--full">
        <label for="message">Personal Reference / Message</label>
        <textarea id="message" name="message" rows="4" placeholder="Tell us a little about yourself..."></textarea>
      </div>

      <button type="submit" class="btn btn-primary signup__submit">Send</button>
    </form>
  </div>
</section>

<style>
  .signup {
    padding: 5rem 0;
  }

  .signup__features {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 2rem;
    margin-bottom: 3rem;
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
  }

  .signup__feature {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.05rem;
    color: var(--color-primary);
  }

  .signup__feature-icon {
    font-size: 1.4rem;
  }

  .signup__form {
    max-width: 560px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .signup__field {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .signup__field--full {
    grid-column: 1 / -1;
  }

  .signup__field label {
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--color-primary);
  }

  .signup__required {
    color: var(--color-accent);
  }

  .signup__field input,
  .signup__field textarea {
    padding: 0.75rem 1rem;
    border: 2px solid #ddd;
    border-radius: var(--radius);
    font-size: 1rem;
    font-family: var(--font-body);
    transition: border-color 0.3s ease;
    background: var(--color-white);
  }

  .signup__field input:focus,
  .signup__field textarea:focus {
    outline: none;
    border-color: var(--color-accent);
  }

  .signup__submit {
    grid-column: 1 / -1;
    justify-self: center;
    min-width: 180px;
    margin-top: 0.5rem;
  }

  @media (max-width: 600px) {
    .signup__form {
      grid-template-columns: 1fr;
    }
  }
</style>
