---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Watch Stories – Recovery Roads"
  description="Watch recovery stories shared by real people on their journey. Road-trip style interviews capturing experience, strength, and hope."
>
  <section class="page-hero parallax" style="background-image: url('/images/watch-bg.jpg')">
    <div class="container">
      <h1>Watch Stories</h1>
      <p class="page-hero__sub">
        Real stories, real people, real recovery. Pull up a seat and listen in.
      </p>
    </div>
  </section>

  <section class="section videos">
    <div class="container">
      <div class="videos__grid">
        <!-- YouTube embed: Intro video -->
        <div class="videos__card">
          <div class="videos__embed">
            <iframe
              src="https://www.youtube.com/embed?listType=playlist&list=UUBJsUr5yUwVVdySiV-L3a3Q"
              title="Recovery Roads YouTube Channel"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              loading="lazy"
            ></iframe>
          </div>
          <h3>Recovery Roads Channel</h3>
          <p>Browse all of our recovery stories on YouTube.</p>
        </div>

        <div class="videos__card">
          <div class="videos__embed">
            <div class="videos__placeholder">
              <svg width="64" height="64" viewBox="0 0 24 24" fill="rgba(255,255,255,0.7)" aria-hidden="true">
                <path d="M8 5v14l11-7z"/>
              </svg>
              <span>More stories coming soon</span>
            </div>
          </div>
          <h3>New Stories</h3>
          <p>We're always on the road capturing new stories. Check back often!</p>
        </div>
      </div>

      <div class="videos__cta">
        <p>Want to see more?</p>
        <a href="https://www.youtube.com/channel/UCBJsUr5yUwVVdySiV-L3a3Q" target="_blank" rel="noopener" class="btn btn-primary">
          Visit Our YouTube Channel
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    text-align: center;
    padding: 8rem 1.5rem 5rem;
    min-height: 350px;
    display: flex;
    align-items: center;
  }

  .page-hero h1 {
    color: var(--color-white);
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: 0.75rem;
  }

  .page-hero__sub {
    font-size: 1.15rem;
    opacity: 0.85;
    max-width: 500px;
    margin: 0 auto;
    color: rgba(255,255,255,0.9);
  }

  .videos__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
    gap: 2.5rem;
    margin-bottom: 3rem;
  }

  .videos__card {
    background: var(--color-white);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: 0 2px 16px rgba(0,0,0,0.08);
    transition: transform 0.3s ease;
  }

  .videos__card:hover {
    transform: translateY(-3px);
  }

  .videos__embed {
    aspect-ratio: 16 / 9;
    background: #111;
  }

  .videos__embed iframe {
    width: 100%;
    height: 100%;
    border: none;
  }

  .videos__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    color: rgba(255,255,255,0.6);
    background: linear-gradient(135deg, #1a2f1a, var(--color-primary));
    font-size: 1rem;
  }

  .videos__card h3 {
    padding: 1.25rem 1.25rem 0.5rem;
    font-size: 1.2rem;
  }

  .videos__card p {
    padding: 0 1.25rem 1.5rem;
    color: var(--color-gray);
    font-size: 0.95rem;
  }

  .videos__cta {
    text-align: center;
    padding: 2rem 0;
  }

  .videos__cta p {
    font-size: 1.1rem;
    margin-bottom: 1rem;
    color: var(--color-dark);
  }

  @media (max-width: 400px) {
    .videos__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
