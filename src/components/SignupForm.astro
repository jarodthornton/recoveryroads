---
// SignupForm.astro – Matching original recoveryroads.com signup form
---

<section class="signup" id="signup">
  <div class="container">
    <h2 class="section__title">Are You Ready?</h2>

    <form class="signup__form" name="signup" method="POST" data-netlify="true" netlify-honeypot="bot-field">
      <input type="hidden" name="form-name" value="signup">
      <p hidden><input name="bot-field"></p>

      <p class="signup__row">
        <label for="name">Your Name <span class="signup__required">(required)</span></label>
        <input type="text" id="name" name="name" required placeholder="First Lastname">
      </p>

      <p class="signup__row">
        <label for="email">Your Email <span class="signup__required">(required)</span></label>
        <input type="email" id="email" name="email" required placeholder="you@youremail.com">
      </p>

      <p class="signup__row">
        <label for="sobrietyDate">Sobriety Date</label>
        <input type="text" id="sobrietyDate" name="sobrietyDate" placeholder="11/25/2017">
      </p>

      <p class="signup__row">
        <label for="message">Personal Reference / Message</label>
        <textarea id="message" name="message" rows="4" placeholder="(name of person) has been with me throughout my entire recovery and can speak for the work I've done. I would love to share my story!"></textarea>
      </p>

      <p class="signup__row">
        <button type="submit" class="btn btn-primary">Send</button>
      </p>
    </form>
  </div>
</section>

<style>
  .signup {
    padding: 5rem 0;
    background: var(--color-white);
  }

  .signup__form {
    max-width: 540px;
    margin: 2.5rem auto 0;
  }

  .signup__row {
    margin-bottom: 1.25rem;
  }

  .signup__row label {
    display: block;
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--color-dark);
    margin-bottom: 0.35rem;
    font-family: var(--font-heading);
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .signup__required {
    font-weight: 400;
    color: var(--color-gray);
    text-transform: none;
    font-family: var(--font-body);
  }

  .signup__row input,
  .signup__row textarea {
    width: 100%;
    padding: 0.8rem 1rem;
    border: 1px solid var(--color-light-gray);
    border-radius: 4px;
    font-size: 1rem;
    font-family: var(--font-body);
    transition: border-color 0.3s ease;
    background: #fafafa;
  }

  .signup__row input:focus,
  .signup__row textarea:focus {
    outline: none;
    border-color: var(--color-blue);
    background: var(--color-white);
    box-shadow: 0 0 0 3px rgba(72, 156, 211, 0.1);
  }

  .signup__row button {
    width: 100%;
    padding: 1rem;
    font-size: 1rem;
    margin-top: 0.5rem;
  }
</style>
