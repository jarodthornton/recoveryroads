---
import BaseLayout from "../layouts/BaseLayout.astro";
import SignupForm from "../components/SignupForm.astro";
---

<BaseLayout
  title="Recovery Roads – Stories on the Go"
  description="Unscripted, stress-free one-on-one creative capture of short recovery stories to share experience, strength and hope."
>
  <!-- Hero Section -->
  <section class="hero">
    <div class="hero__overlay"></div>
    <div class="container hero__content">
      <h1 class="hero__title">RECOVERY ROADS</h1>
      <p class="hero__tagline">
        We all have a story, our own journey – the road to recovery
      </p>
      <div class="hero__cta">
        <a href="/watch" class="btn btn-primary">Watch Stories</a>
        <a href="#signup" class="btn btn-secondary">Share Your Story</a>
      </div>
    </div>
  </section>

  <!-- Intro Section -->
  <section class="intro section">
    <div class="container">
      <h2 class="section__title">Stories on the Go</h2>
      <p class="section__subtitle">
        Unscripted stress-free one-on-one creative capture of short recovery stories to share experience, strength and hope.
      </p>
      <div class="intro__video">
        <div class="intro__video-placeholder">
          <svg width="80" height="80" viewBox="0 0 24 24" fill="rgba(255,255,255,0.9)" aria-hidden="true">
            <path d="M8 5v14l11-7z"/>
          </svg>
          <p>Watch the intro video</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="section section--alt" id="learn">
    <div class="container">
      <h2 class="section__title">Why Recovery Roads?</h2>
      <div class="features">
        <div class="features__card">
          <div class="features__icon" aria-hidden="true">&#128253;</div>
          <h3>Real Stories</h3>
          <p>Authentic, unscripted conversations with real people sharing their recovery journey.</p>
        </div>
        <div class="features__card">
          <div class="features__icon" aria-hidden="true">&#127909;</div>
          <h3>On the Road</h3>
          <p>Interviews captured road-trip style – relaxed, natural, and in the fresh air.</p>
        </div>
        <div class="features__card">
          <div class="features__icon" aria-hidden="true">&#128170;</div>
          <h3>Strength &amp; Hope</h3>
          <p>Every story shared carries the power to inspire and uplift someone else.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Signup -->
  <SignupForm />

  <!-- Memorial -->
  <section class="memorial section section--alt">
    <div class="container memorial__content">
      <p class="memorial__text">
        In loving memory of<br />
        <strong>Jesse Allen Roth</strong> &amp; <strong>Stephanie Suzanne Crawford</strong>
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    position: relative;
    min-height: 85vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--color-primary) 0%, #0f1f2e 60%, #1a2f1a 100%);
    background-size: cover;
    background-position: center;
    overflow: hidden;
  }

  .hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 30% 50%, rgba(224, 123, 60, 0.15) 0%, transparent 60%),
                radial-gradient(ellipse at 70% 80%, rgba(212, 169, 106, 0.1) 0%, transparent 50%);
  }

  .hero__content {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 4rem 1.5rem;
  }

  .hero__title {
    color: var(--color-white);
    font-size: clamp(2.5rem, 7vw, 5rem);
    letter-spacing: 0.06em;
    margin-bottom: 1rem;
    text-shadow: 0 2px 8px rgba(0,0,0,0.3);
  }

  .hero__tagline {
    color: rgba(255,255,255,0.85);
    font-size: clamp(1.1rem, 2.5vw, 1.5rem);
    max-width: 600px;
    margin: 0 auto 2.5rem;
    font-style: italic;
    line-height: 1.6;
  }

  .hero__cta {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .hero__cta .btn-secondary {
    color: var(--color-white);
    border-color: var(--color-white);
  }

  .hero__cta .btn-secondary:hover {
    background: var(--color-white);
    color: var(--color-primary);
  }

  .intro__video {
    max-width: 700px;
    margin: 2rem auto 0;
  }

  .intro__video-placeholder {
    aspect-ratio: 16 / 9;
    background: linear-gradient(135deg, #2a4a3a, var(--color-primary));
    border-radius: var(--radius);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    color: rgba(255,255,255,0.8);
    cursor: pointer;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .intro__video-placeholder:hover {
    transform: scale(1.02);
    box-shadow: 0 8px 24px rgba(0,0,0,0.2);
  }

  .features {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
    margin-top: 2rem;
  }

  .features__card {
    background: var(--color-white);
    padding: 2.5rem 2rem;
    border-radius: var(--radius);
    text-align: center;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .features__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.1);
  }

  .features__icon {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .features__card h3 {
    margin-bottom: 0.75rem;
  }

  .features__card p {
    color: var(--color-gray);
    line-height: 1.6;
  }

  .memorial {
    text-align: center;
  }

  .memorial__text {
    font-size: 1.15rem;
    color: var(--color-primary);
    line-height: 1.8;
  }

  .memorial__text strong {
    color: var(--color-accent);
  }
</style>
